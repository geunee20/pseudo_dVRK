    <collision>
      <geometry>
        <mesh filename="Top Panel.STL" />
      </geometry>
    </collision>
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <mass value=".9" />
      <inertia ixx="9.0" ixy="0.0" ixz="0.0" iyy="9.0" iyz="0.0" izz="9.0" />
    </inertial>
  </link>
  <joint name="outer_yaw_joint" type="revolute">
    <parent link="top_panel" />
    <child link="outer_yaw_link" />
    <origin rpy="0 0 1.57079632679" xyz="0 0 0" />
    <axis xyz="0 0 1" />
    <limit effort="50.0" lower="-1.308996939" upper="0.785398163397" velocity="2" />
    <joint_properties damping="1.0" friction="0.0" />
  </joint>
