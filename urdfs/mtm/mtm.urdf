<?xml version='1.0' encoding='utf-8'?>
<robot name="mtm">
  <link name="world" />
  <joint name="fixed_joint" type="fixed">
    <parent link="world" />
    <child link="top_panel" />
    <origin rpy="0 0 0" xyz="0 0 0" />
  </joint>
  <link name="top_panel">
    <visual>
      <geometry>
        <mesh filename="Top Panel.dae" />
      </geometry>
