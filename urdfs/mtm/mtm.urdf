  </link>
  <joint name="shoulder_pitch_joint" type="revolute">
    <parent link="outer_yaw_link" />
    <child link="back_parallel_link" />
    <origin rpy="-1.57079632679 -1.57079632679 0" xyz="0 0 -0.19037" />
    <axis xyz="0 0 1" />
    <limit effort="100.0" lower="-0.785398163397" upper="0.785398163397" velocity="10" />
    <joint_properties damping="1.0" friction="0.0" />
  </joint>
  <joint name="shoulder_pitch_parallel_joint" type="revolute">
